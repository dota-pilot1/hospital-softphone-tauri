{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hospital Softphone",
  "version": "0.1.0",
  "identifier": "com.hospital-softphone.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1424",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {},
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hospital Softphone",
        "width": 1180,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": -100,
          "y": 0
        },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
